#!/usr/bin/env bash
# sbx-init.sh — One-time host setup for Claude sandboxes.
#
# Ensures global secrets and network policies are in place.
# Safe to re-run: each step is skipped if already configured.
set -euo pipefail

# ── Secrets ────────────────────────────────────────────────────────────────
existing_secrets=$(sbx secret ls 2>/dev/null || true)

if echo "$existing_secrets" | grep -q 'anthropic'; then
    echo "Secret 'anthropic' already exists, skipping."
else
    if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
        echo "Error: ANTHROPIC_API_KEY is not set." >&2
        exit 1
    fi
    echo "Setting global secret 'anthropic'..."
    sbx secret set -g anthropic -t "$ANTHROPIC_API_KEY"
fi

if echo "$existing_secrets" | grep -q 'github'; then
    echo "Secret 'github' already exists, skipping."
else
    echo "Setting global secret 'github'..."
    sbx secret set -g github -t "$(gh auth token)"
fi

# ── Network policies ──────────────────────────────────────────────────────
existing_policies=$(sbx policy ls 2>/dev/null || true)

needed_domains=()
for domain in mise.jdx.dev mise-java.jdx.dev api.app.shortcut.com cdn.playwright.dev playwright.download.prss.microsoft.com; do
    if echo "$existing_policies" | grep -q "$domain"; then
        echo "Network access for '$domain' already allowed, skipping."
    else
        needed_domains+=("$domain")
    fi
done

if [[ ${#needed_domains[@]} -gt 0 ]]; then
    domains_csv=$(IFS=,; echo "${needed_domains[*]}")
    echo "Allowing network access for: $domains_csv"
    sbx policy allow network "$domains_csv"
fi

echo ""
echo "Host setup complete."
