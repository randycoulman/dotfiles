#!/usr/bin/env bash
# sbx-new — Create a Claude sandbox and hand off to sbx-up for all syncing.
#
# Usage: sbx-new <project-path> [sandbox-name]
#
# One-time host prerequisites: run sbx-init first.
# All syncing is delegated to sbx-up (single consolidated agent exec) so the
# two paths stay aligned and the sandbox is only started a couple of times.
set -euo pipefail
trap 'echo "sbx-new: failed at line $LINENO: $BASH_COMMAND" >&2' ERR

usage() {
    echo "Usage: $(basename "$0") <project-path> [sandbox-name]" >&2
    exit 1
}

[[ $# -lt 1 ]] && usage

PROJECT_PATH="$(cd "$1" && pwd)"
PROJECT_NAME="$(basename "$PROJECT_PATH")"
# Sanitize name: only letters, numbers, hyphens, periods, plus signs allowed by sbx
SANDBOX_NAME="${2:-claude-$(printf '%s' "$PROJECT_NAME" | tr -cs 'a-zA-Z0-9.+-' '-')}"

# ── Memory bind-mount prep ─────────────────────────────────────────────────
# Claude Code stores per-project memories under ~/.claude/projects/<slug>/memory.
# Mounting that dir into the sandbox gives the host and all sandboxes for this
# project a shared memory pool. The slug collapses '/' and '.' to '-'.
PROJECT_SLUG="$(printf '%s' "$PROJECT_PATH" | tr '/.' '-')"
HOST_MEMORY_DIR="$HOME/.claude/projects/$PROJECT_SLUG/memory"
mkdir -p "$HOST_MEMORY_DIR"

# ── Create sandbox with project + memory mounts ────────────────────────────
echo "Creating sandbox '$SANDBOX_NAME' for $PROJECT_PATH..."
sbx create --name "$SANDBOX_NAME" claude "$PROJECT_PATH" "$HOST_MEMORY_DIR"

# ── Sync everything ────────────────────────────────────────────────────────
sbx-up "$PROJECT_PATH" "$SANDBOX_NAME"

echo "Attach with: sbx run $SANDBOX_NAME"
